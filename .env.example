# Copie este arquivo para ".env" e ajuste os valores.

# String de conexão com o Postgres. Ao rodar via `docker compose up`, o app usa
# a variável DATABASE_URL definida no docker-compose.yml (aponta para o serviço "db").
# Ao rodar `npm run dev` direto na máquina (fora do Docker), use "localhost".
DATABASE_URL="postgresql://central:central_dev_pw@localhost:5432/central_contabil?schema=public"

# Usados pelo Postgres do docker-compose para criar o banco/usuário na primeira vez.
POSTGRES_USER="central"
POSTGRES_PASSWORD="central_dev_pw"
POSTGRES_DB="central_contabil"

# Chave secreta do Auth.js — gere uma nova em produção com: npx auth secret
AUTH_SECRET="troque-esta-chave-em-producao"
AUTH_URL="http://localhost:4010"

# Chave da API da Anthropic, usada apenas no servidor (mapeamento de colunas
# e leitura de PDF por IA na Conciliação Bancária). Deixe em branco para
# manter a IA desativada (cai no fallback por palavras-chave).
ANTHROPIC_API_KEY=""

# Token da API do Acessórias, usado para sincronizar a Gestão de Entregas
# automaticamente (sem precisar anexar arquivo). Gerado em: Configurações > API Token.
# Deixe em branco para manter a sincronização desativada.
ACESSORIAS_API_TOKEN=""

# Chaves VAPID para notificações push (Web Push) — gere o seu par com
# `npx web-push generate-vapid-keys`. A pública (NEXT_PUBLIC_...) vai pro
# navegador, a privada fica só no servidor. Deixe em branco para manter
# o push desativado (a central de notificações dentro do site continua
# funcionando normalmente sem isso).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:contato@navecon.net.br"
